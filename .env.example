# Google Sheets সিঙ্ক (ফ্রি এবং সবচেয়ে সহজ!)
# একবার সেটআপ করলে সব ডাটা Google-এ সিঙ্ক হবে

# সেটআপ নির্দেশনা: download/google-sync-setup.html দেখুন

NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# উদাহরণ:
# NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzXXXXXX/exec
